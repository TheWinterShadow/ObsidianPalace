# Local development configuration.
# Copy to .env and fill in your values.
# In production, these are injected via Secret Manager with the OBSIDIAN_PALACE_ prefix.

# Google OAuth 2.0 (for Claude Custom Connector auth)
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
ALLOWED_EMAIL=your-email@gmail.com

# Vault configuration
VAULT_PATH=/data/vault
CHROMADB_PATH=/data/chromadb

# Obsidian Sync (ob CLI credentials injected at container startup)
OBSIDIAN_SYNC_MODE=bidirectional

# AI placement (for determining where new files go in the vault)
ANTHROPIC_API_KEY=sk-ant-...

# Server
HOST=0.0.0.0
PORT=8080
LOG_LEVEL=info
