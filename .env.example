# Local development configuration.
# Copy to .env and fill in your values.
# pydantic-settings expects the OBSIDIAN_PALACE_ prefix on all variables.

# Google OAuth 2.0 (for Claude Custom Connector auth)
OBSIDIAN_PALACE_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
OBSIDIAN_PALACE_GOOGLE_CLIENT_SECRET=your-client-secret
OBSIDIAN_PALACE_ALLOWED_EMAIL=your-email@gmail.com

# Vault configuration
OBSIDIAN_PALACE_VAULT_PATH=/data/vault
OBSIDIAN_PALACE_CHROMADB_PATH=/data/chromadb

# MemPalace / Search
OBSIDIAN_PALACE_MEMPALACE_ENABLED=true
OBSIDIAN_PALACE_MEMPALACE_WING=obsidian
OBSIDIAN_PALACE_MEMPALACE_COLLECTION_NAME=mempalace_drawers

# Obsidian Sync (ob CLI credentials injected at container startup)
OBSIDIAN_PALACE_OBSIDIAN_SYNC_MODE=bidirectional

# AI placement (for determining where new files go in the vault)
OBSIDIAN_PALACE_ANTHROPIC_API_KEY=sk-ant-...

# Server
OBSIDIAN_PALACE_HOST=0.0.0.0
OBSIDIAN_PALACE_PORT=8080
OBSIDIAN_PALACE_LOG_LEVEL=info
